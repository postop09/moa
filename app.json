{
  "expo": {
    "name": "모아(Moa)",
    "slug": "moa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./shared/assets/icons/icon.png",
    "scheme": "moa",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.postop.moa",
      "supportsTablet": true
    },
    "android": {
      "package": "com.postop.moa",
      "adaptiveIcon": {
        "backgroundColor": "#0a7ea4",
        "foregroundImage": "./shared/assets/icons/android-icon-foreground.png",
        "backgroundImage": "./shared/assets/icons/android-icon-background.png",
        "monochromeImage": "./shared/assets/icons/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./shared/assets/icons/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./shared/assets/images/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0a7ea4",
          "dark": {
            "backgroundColor": "#0a7ea4"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
